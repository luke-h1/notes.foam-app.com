{
  "compatibility_date": "2026-03-17",
  "compatibility_flags": ["global_fetch_strictly_public"],
  "name": "foam-notes",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "notes-db",
      "database_id": "00000000-0000-4000-8000-000000000001",
    },
  ],
}
