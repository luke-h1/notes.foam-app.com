---
export const prerender = false;

import { DeleteNoteClient } from "./_DeleteNoteClient";
import { isValidNoteId } from "@/lib/validate";
import Layout from "../../../layouts/Layout.astro";

const { id } = Astro.params;
const token = Astro.url.searchParams.get("token");
const validId = isValidNoteId(id);

if (!validId) {
  Astro.response.status = 404;
}
---

<Layout title={validId ? "Delete note" : "Not found"}>
  {
    validId ? (
      <div class="mx-auto max-w-md px-4 py-16 sm:py-24">
        <h1 class="text-xl font-semibold text-zinc-900 dark:text-white">
          Delete note
        </h1>
        <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">
          This removes the note from the server permanently. The short id is{" "}
          <span class="font-mono text-violet-600 dark:text-violet-400">
            /n/{id}
          </span>
        </p>
        <DeleteNoteClient client:load noteId={id!} initialToken={token} />
      </div>
    ) : (
      <div class="mx-auto max-w-md px-4 py-24 text-center">
        <h1 class="text-xl font-semibold text-zinc-900 dark:text-white">
          Not found
        </h1>
        <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">
          This link is invalid or the note no longer exists.
        </p>
        <a
          href="/"
          class="mt-6 inline-block text-sm font-medium text-violet-600 hover:underline dark:text-violet-400"
        >
          Create a new note
        </a>
      </div>
    )
  }
</Layout>
