---
export const prerender = false;

import { env } from "cloudflare:workers";

import { CharBreakdown } from "./_CharBreakdown";
import { NoteCopyBar } from "./_NoteCopyBar";
import { getNote } from "@/lib/note-service";
import { isValidNoteId } from "@/lib/validate";
import Layout from "../../layouts/Layout.astro";

const { id } = Astro.params;

const note = isValidNoteId(id) ? await getNote(env.notes_db, id) : null;

if (!note) {
  Astro.response.status = 404;
}
---

<Layout title={note ? `Note ${note.id}` : "Note not found"}>
  {
    note ? (
      <article class="mx-auto max-w-3xl px-4 py-10 sm:px-6">
        <header class="mb-6 flex flex-wrap items-start justify-between gap-4">
          <div>
            <p class="font-mono text-sm text-violet-600 dark:text-violet-400">
              /n/{note.id}
            </p>
            <p class="mt-1 text-xs text-zinc-500 dark:text-zinc-400">
              {new Date(note.created_at).toLocaleString()}
            </p>
            <CharBreakdown client:load noteId={note.id} />
          </div>
          <NoteCopyBar client:load noteUrl={Astro.url.href} noteId={note.id} />
        </header>
        <pre class="whitespace-pre-wrap break-words rounded-2xl border border-zinc-200 bg-white p-6 font-mono text-sm leading-relaxed text-zinc-800 shadow-sm dark:border-zinc-800 dark:bg-zinc-900/50 dark:text-zinc-100">
          {note.content}
        </pre>
        <p class="mt-8 text-center text-sm text-zinc-500 dark:text-zinc-400">
          <a
            href="/"
            class="text-violet-600 hover:underline dark:text-violet-400"
          >
            New note
          </a>
        </p>
      </article>
    ) : (
      <div class="mx-auto max-w-md px-4 py-24 text-center">
        <h1 class="text-xl font-semibold text-zinc-900 dark:text-white">
          Note not found
        </h1>
        <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">
          It may have been deleted or the link is wrong.
        </p>
        <a
          href="/"
          class="mt-6 inline-block text-sm font-medium text-violet-600 hover:underline dark:text-violet-400"
        >
          Create a new note
        </a>
      </div>
    )
  }
</Layout>
