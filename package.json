{
  "name": "notes.foam-app.com",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "bun@1.3.5",
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "check": "astro check",
    "lint": "eslint \"src/**/*.{ts,tsx,astro}\" \"astro.config.mjs\" \"eslint.config.mjs\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx,astro}\" \"astro.config.mjs\" \"eslint.config.mjs\" --fix",
    "verify": "bun run lint && bun run check && bun run build",
    "preview": "astro preview",
    "astro": "astro",
    "generate-types": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply notes-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply notes-db --remote",
    "deploy": "bun run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.3",
    "@astrojs/react": "^5.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.0.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "wrangler": "^4.76.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@eslint/js": "9.22.0",
    "@types/node": "22",
    "eslint": "9.22.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  }
}
